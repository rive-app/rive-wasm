{
  "npm": {
    "publish": false
  },
  "git": {
    "addUntrackedFiles": true,
    "commitMessage": "chore: tag ${version}",
    "requireCleanWorkingDir": false
  },
  "github": {
    "release": true,
    "releaseName": "${version}",
    "releaseNotes": "npx auto-changelog --stdout --unreleased --commit-limit false --template keepachangelog --sort-commits date-desc --hide-credit"
  },
  "hooks": {
    "after:version:bump": [
      "npm run bumpVersions",
      "npm run build:all",
      "npm test",
      "npm run changelog",
      "npm run publish:all",
      "git add ../CHANGELOG.md"
    ]
  }
}
